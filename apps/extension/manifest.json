{
  "manifest_version": 3,
  "name": "MeetMind AI Live Notes",
  "version": "1.0.0",
  "description": "Capture live meeting audio and generate AI notes.",
  "permissions": [
    "tabCapture",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "ws://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MeetMind AI"
  }
}